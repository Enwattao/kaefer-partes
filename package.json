{
  "name": "kaefer-partes",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "dist": "vite build && electron-builder --win portable"
  },
  "dependencies": {
    "date-fns": "^4.4.0",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "es.kaefer.partes-comida",
    "productName": "KAEFER Partes de Comida",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    },
    "portable": {
      "artifactName": "KAEFER-Partes-Comida.exe"
    },
    "files": [
      "dist/**",
      "electron/**",
      "public/**"
    ],
    "extraResources": []
  }
}
